# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_strong_refresh_token_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MongoDB (Atlas Vector Search) ───────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/swiftchat?retryWrites=true&w=majority

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Google OAuth ──────────────────────.────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── AI Services ───────────────────────────────────────
AI_CAPTION_SERVICE_URL=http://localhost:8001
AI_EMOTION_SERVICE_URL=http://localhost:8002
AI_SEARCH_SERVICE_URL=http://localhost:8003
AI_CHAT_SERVICE_URL=http://localhost:8004
AI_MODERATION_SERVICE_URL=http://localhost:8005
AI_SERVICE_KEY=your_internal_ai_service_key
NVIDIA_API_KEY=your_nvidia_api_key_here

# ─── Media Upload ──────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100

# ─── CORS ──────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Email (Nodemailer) ────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail
EMAIL_PASS=your_app_password

